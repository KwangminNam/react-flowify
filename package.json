{
  "name": "react-flowify",
  "version": "0.1.0",
  "description": "Declarative JSX components replacing React imperative patterns",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "changeset": "changeset",
    "release": "pnpm build && changeset publish",
    "version": "changeset version"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "dependencies": {
    "react-error-boundary": "^5.0.0"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.0",
    "@testing-library/jest-dom": "^6.6.0",
    "@testing-library/react": "^16.1.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "jsdom": "^25.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "keywords": [
    "react",
    "declarative",
    "jsx",
    "components",
    "flowify"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/KwangminNam/flowify.git"
  },
  "homepage": "https://github.com/KwangminNam/flowify#readme",
  "bugs": {
    "url": "https://github.com/KwangminNam/flowify/issues"
  },
  "author": "KwangminNam",
  "sideEffects": false,
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}